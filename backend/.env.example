DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (optional override): CSRF_TRUSTED_ORIGINS=https://kentsel.ercaninsaat.com,https://kentsel-api.ercaninsaat.com
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
API_PAGE_SIZE=50
DEMO_USER_PASSWORD=demo1234
# All logged-in users share every project (father/brother/you). Set false for strict RBAC.
SHARED_PROJECT_ACCESS=true
POSTGRES_DB=minierp
POSTGRES_USER=minierp
POSTGRES_PASSWORD=minierp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Railway/Heroku: set DATABASE_URL instead of POSTGRES_* (preferred in production)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Production only
# DJANGO_SECURE_COOKIES=true
