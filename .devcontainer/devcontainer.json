{
  "name": "mini-erp",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [5432, 8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "batisteo.vscode-django"
      ]
    }
  },
  "postCreateCommand": "pip install -e './backend[dev]' && cd backend && python manage.py migrate"
}
